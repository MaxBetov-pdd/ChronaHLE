+bool HighNarrowingInstruction(TranslatorVisitor& v, bool D, size_t sz, size_t Vn, size_t Vd, bool N, bool M, size_t Vm, HighNarrowingOperation operation, RoundingBehavior rounding) {
+    if (sz == 0b11) {
+        return v.DecodeError();
+    }
+
+    if (mcl::bit::get_bit<0>(Vn) || mcl::bit::get_bit<0>(Vm)) {
+        return v.UndefinedInstruction();
+    }
+
+    const size_t source_esize = 16U << sz;
+    const size_t destination_esize = source_esize / 2;
+    const auto d = ToVector(false, Vd, D);
+    const auto n = ToVector(true, Vn, N);
+    const auto m = ToVector(true, Vm, M);
+
+    const auto reg_n = v.ir.GetVector(n);
+    const auto reg_m = v.ir.GetVector(m);
+    auto wide = operation == HighNarrowingOperation::Add
+                  ? v.ir.VectorAdd(source_esize, reg_n, reg_m)
+                  : v.ir.VectorSub(source_esize, reg_n, reg_m);
+
+    if (rounding == RoundingBehavior::Round) {
+        const u64 round_constant = 1ULL << (destination_esize - 1);
+        const auto round_operand = v.ir.VectorBroadcast(source_esize, v.I(source_esize, round_constant));
+        wide = v.ir.VectorAdd(source_esize, wide, round_operand);
+    }
+
+    const auto high_half = v.ir.VectorLogicalShiftRight(source_esize, wide, static_cast<u8>(destination_esize));
+    const auto result = v.ir.VectorNarrow(source_esize, high_half);
+    v.ir.SetVector(d, result);
+    return true;
+}
