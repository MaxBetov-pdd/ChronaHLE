@@ -18,6 +18,37 @@ static A32::UserConfig GetUserConfig(ArmTestEnv* testenv) {
     return user_config;
 }
 
+TEST_CASE("arm: vaddhn.i32 with overlapping destination", "[arm][A32][ASIMD]") {
+    ArmTestEnv test_env;
+    A32::Jit jit{GetUserConfig(&test_env)};
+    test_env.code_mem = {
+        0xf2dee4aa,  // vaddhn.i32 d30, q15, q13
+        0xeafffffe,  // b +#0
+    };
+
+    // q15, which overlaps the d30 destination.
+    jit.ExtRegs()[60] = 0x00010002;
+    jit.ExtRegs()[61] = 0x7fff0001;
+    jit.ExtRegs()[62] = 0xffff0000;
+    jit.ExtRegs()[63] = 0x12345678;
+
+    // q13.
+    jit.ExtRegs()[52] = 0x00020003;
+    jit.ExtRegs()[53] = 0x0001ffff;
+    jit.ExtRegs()[54] = 0x00020001;
+    jit.ExtRegs()[55] = 0xedcba988;
+
+    jit.Regs()[15] = 0;
+    jit.SetCpsr(0x00000010);  // User-mode
+
+    test_env.ticks_left = 1;
+    jit.Run();
+
+    REQUIRE(jit.ExtRegs()[60] == 0x80010003);
+    REQUIRE(jit.ExtRegs()[61] == 0x00000001);
+    REQUIRE(jit.Regs()[15] == 4);
+}
